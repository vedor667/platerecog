# Copy to .env and fill in. Never commit the real .env.

# Get a token at https://app.platerecognizer.com/ (free tier available).
PLATE_API_TOKEN=your_token_here

# Port the Node app listens on (nginx will proxy to this).
PORT=3000

# Optional region hint. Leave EMPTY to let the API auto-detect (recommended —
# the "th" code is rejected unless region-prediction is enabled on your plan).
PLATE_REGIONS=

# Override only if self-hosting Plate Recognizer's SDK instead of the cloud API.
# PLATE_API_URL=https://api.platerecognizer.com/v1/plate-reader/
